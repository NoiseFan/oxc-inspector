{
    "name": "oxc-inspector",
    "type": "module",
    "description": "A visual tool for inspecting and understanding your oxlint and oxfmt config.",
    "packageManager": "pnpm@10.15.1",
    "homepage": "https://github.com/lonewolfyx/oxc-inspector",
    "bugs": {
        "url": "https://github.com/lonewolfyx/oxc-inspector/issues"
    },
    "scripts": {
        "build": "nuxt build",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "typecheck": "nuxt typecheck",
        "lint": "eslint .",
        "lint:fix": "eslint --fix",
        "prepare": "simple-git-hooks"
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.2.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-vue-next": "^0.545.0",
        "reka-ui": "^2.9.0",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.1",
        "vue": "^3.5.29",
        "vue-router": "^4.6.4"
    },
    "devDependencies": {
        "@nuxt/content": "^3.12.0",
        "@nuxt/eslint": "^1.15.2",
        "@nuxt/icon": "^2.2.1",
        "@vueuse/nuxt": "^14.2.1",
        "eslint": "^9.39.4",
        "lint-staged": "^16.3.2",
        "nuxt": "^4.3.1",
        "oxlint": "^1.51.0",
        "picocolors": "^1.1.1",
        "shadcn-nuxt": "^2.4.3",
        "simple-git-hooks": "^2.13.1",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.9.3"
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged",
        "commit-msg": "node scripts/verify-commit.js"
    },
    "license": "MIT",
    "lint-staged": {
        "*": "eslint --fix"
    }
}
